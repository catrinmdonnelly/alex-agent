# Alex, environment variables
# Copy to .env for local runs, or add as GitHub Actions secrets for the scheduled run.

# REQUIRED
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# REQUIRED, your site in Search Console.
# - For a domain property:  sc-domain:example.com
# - For a URL-prefix property:  https://example.com/
# Look at the property selector in Search Console to see exactly which one you have.
GSC_SITE_URL=sc-domain:example.com

# REQUIRED, the full JSON content of your service account key file
# (See SETUP.md step 3 for how to generate this.)
# In a .env file, paste the entire JSON on one line, escaping quotes if needed.
# In GitHub Actions, paste the raw JSON as the secret value, no escaping needed.
GSC_CREDENTIALS_JSON=

# RECOMMENDED
BUSINESS_NAME=Your Business Name
ANTHROPIC_MODEL=claude-sonnet-4-6
AGENT_TIMEZONE=Europe/London

# OPTIONAL, failure email alerts
FAILURE_EMAIL_TO=
FAILURE_EMAIL_FROM=
FAILURE_EMAIL_SMTP_HOST=smtp.gmail.com
FAILURE_EMAIL_SMTP_PASS=
